[Unit]
Description=UrbanLease Rental Scraper
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/urbanlease/scraper
EnvironmentFile=/opt/urbanlease/scraper/.env
ExecStart=/opt/urbanlease/venv/bin/gunicorn --workers 1 --bind 127.0.0.1:5000 --timeout 120 wsgi:application
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
